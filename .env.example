# Copy this file to .env before running locally or in Docker.
# Spring Boot reads it through spring.config.import in application.properties.

SUPABASE_DB_URL=jdbc:postgresql://aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require
SUPABASE_DB_USERNAME=postgres.your_project_ref
SUPABASE_DB_PASSWORD=your_database_password
GEMINI_API_KEY=your_api_key_here
DB_MAX_POOL_SIZE=2
DB_MIN_IDLE=1
DB_CONNECTION_TIMEOUT_MS=10000
